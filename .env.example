# Environment Variables Example
# Copy this to .env file and fill in your actual values

# MongoDB Atlas Connection String
MONGODB_URI="mongodb+srv://your-username:your-password@your-cluster.mongodb.net/?appName=Cluster0"

# Database Name
MONGODB_DB_NAME="portfolio"

# Note: For production deployments, set these in your hosting provider's environment variables:
# - Netlify: Site settings > Environment variables
# - Vercel: Project settings > Environment variables
